# ── Google Maps ──────────────────────────────────────────────────────────────
#
# Public key — loaded in the browser by @vis.gl/react-google-maps.
# Restrict this key in Google Cloud Console to:
#   - Maps JavaScript API
#   - HTTP referrers (your domain)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_browser_restricted_maps_key_here

# Server-side key — used ONLY in Next.js API routes (/api/places/*).
# Restrict this key in Google Cloud Console to:
#   - Places API (New)
#   - Server IP addresses (optional, for extra security)
GOOGLE_MAPS_API_KEY=your_server_places_api_key_here

# ── Map ID (required for dark/aubergine theme + custom markers) ───────────────
#
# 1. Go to Google Cloud Console → Maps Platform → Map Styles
# 2. Create a new style, import the JSON from lib/mapStyles.ts
# 3. Save and publish → you'll get a Map ID
# 4. Paste it here
#
# Without this, the map falls back to DEMO_MAP_ID (default style,
# but AdvancedMarker / custom circular markers still work).
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your_map_id_here
