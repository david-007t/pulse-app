# Copy this file to .env.local and fill in your values.
# cp .env.example .env.local

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — Google Maps client-side key
# Used by: @vis.gl/react-google-maps (browser, loads the map)
# Restrict in Cloud Console → Credentials:
#   APIs allowed: Maps JavaScript API
#   HTTP referrers: localhost:3000, yourdomain.com
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — Google Maps server-side key
# Used by: /api/places/nearby, /api/places/autocomplete, /api/places/details
# NEVER prefix with NEXT_PUBLIC_ — must stay server-only.
# Restrict in Cloud Console → Credentials:
#   APIs allowed: Places API (New)
#   Application restrictions: Server IP addresses (optional)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Google Maps Map ID for vector map + Cloud Console dark theme
#
# Without this: raster renderer is used and the AUBERGINE_STYLE in
#   lib/mapStyles.ts is applied automatically — dark theme works out of the box.
#
# With this: vector renderer is used (better performance). You must configure
#   the aubergine style manually in Cloud Console → Maps Platform → Map Styles,
#   then paste the Map ID here.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
